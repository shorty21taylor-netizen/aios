DATABASE_URL=postgresql://user:password@localhost:5432/aios
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe billing (Sun 4/27 target) ---
# Required for /api/stripe/checkout and /api/webhooks/stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs must exist in the Stripe dashboard
STRIPE_PRICE_SETUP_ID=price_...     # $2,500 one-time setup
STRIPE_PRICE_MONTHLY_ID=price_...   # $897/mo recurring
# Set to "true" to disable the /dashboard billing gate during early demos
BILLING_GATE_DISABLED=false

# --- Chief-of-Staff audit ---
# Optional: enables n8n workflow health polling
N8N_API_URL=https://summitsales.app.n8n.cloud
N8N_API_KEY=
# Optional: recorded demo for close-readiness gate
DEMO_LOOM_URL=
# Flip to "true" once outreach list is prepped
OUTREACH_LIST_READY=false
